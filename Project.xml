<?xml version="1.0" encoding="utf-8"?>
<project xmlns="http://lime.openfl.org/project/1.0.4" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://lime.openfl.org/project/1.0.4 http://lime.openfl.org/xsd/project-1.0.4.xsd">

	<!-- _________________________ Application Settings _________________________ -->

	<app title="Friday Night Funkin' WTF Engine" file="WTFEngine" main="Main" version="0.1.0" company="VirtuGuy" />

	<app preloader="flixel.system.FlxPreloader" />

	<!-- ____________________________ Window Settings ___________________________ -->

	<window width="1280" height="720" fps="60" background="#000000" hardware="true" vsync="false" />

	<window if="html5" resizable="true" />

	<window if="desktop" orientation="landscape" fullscreen="false" resizable="true" />

	<window if="mobile" orientation="landscape" fullscreen="true" width="0" height="0" />

	<!-- __________________________ WTF Engine Defines _________________________  -->

	<haxedef name="HAS_FPS_COUNTER" />
	<haxedef name="HAS_DISCORD_RPC" />
	<haxedef name="HAS_MODDING" />
	<haxedef name="HAS_SCREENSHOTS" if="debug" />
	<haxedef name="HAS_TITLE_SCARE" />

	<!-- ____________________________ WTF Engine Flags __________________________ -->

	<!-- Kinda taken from Funkin' lol -->
	<haxeflag name="--macro addMetadata('@:build(funkin.util.macro.ZIndexMacro.buildFlxBasic())', 'flixel.FlxBasic')" />
	<haxeflag name="--macro addMetadata('@:build(funkin.util.macro.ZIndexMacro.buildFlxGroup())', 'flixel.group.FlxTypedGroup')" />

	<!-- _____________________________ Path Settings ____________________________ -->

	<set name="BUILD_DIR" value="export/release" />
	<set name="BUILD_DIR" value="export/debug" if="debug" />

	<source path="source" />

	<assets path="assets" />

	<!-- _______________________________ Libraries ______________________________ -->

	<haxelib name="flixel" />
	<haxelib name="hxdiscord_rpc" />
	<haxelib name="json2object" />
	<haxelib name="polymod" />
	<haxelib name="thx.core" />
	<haxelib name="thx.semver" />
	<haxelib name="jsonpath" />
	<haxelib name="jsonpatch" />

	<!-- ______________________________ Haxedefines _____________________________ -->

	<haxedef name="FLX_NO_HEALTH" />
	<haxedef name="FLX_NO_FOCUS_LOST_SCREEN" />
	<haxedef name="FLX_NO_DEBUG" unless="debug" />

	<haxedef name="NAPE_RELEASE_BUILD" unless="debug" />

	<haxedef name="message.reporting" value="pretty" />

	<haxedef name="POLYMOD_MOD_METADATA_FILE" value="meta.json" />
	<haxedef name="POLYMOD_MOD_ICON_FILE" value="icon.png" />

	<!-- Do NOT remove this. This prevents a very dumb error! -->
	<haxedef name="hscriptPos" />

	<!-- _________________________________ Custom _______________________________ -->

	<!-- The engine doesn't support web. Don't even try... -->
	<error value="Web isn't supported you stupid bitch" if="web" />

	<icon path="art/icon.png" />
</project>
